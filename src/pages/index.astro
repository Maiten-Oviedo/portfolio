---
import Badge from '../components/Badge.astro';
import Layout from '../layouts/Layout.astro';
import LinkedInIcon from '../icons/LinkedInIcon.astro';
import NetworkPill from '../components/NetworkPill.astro';
import GithubIcon from '../icons/GithubIcon.astro';
import MailIcon from '../icons/MailIcon.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Proyects from '../components/Proyects.astro';
import InstagramIcon from '../icons/InstagramIcon.astro';
import Studies from '../components/Studies.astro';
---

<Layout 
  title="Portfolio de Maiten - Desarrollador Web Frontend y Programador"
  description="Contratame para solucionar tu problema. Desarrollador Web y Programador. Capáz de crear Webs Únicas."
>
  <main>
    <SectionContainer class="w-full px-[25%] pt-32 pb-32" id="home-section">
      <h1 class="text-white text-4xl font-bold flex gap-x-4 pb-4 items-center">
        Hola, soy Maitén. 
        <a 
          href="https://www.linkedin.com/in/maiten-oviedo/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="flex justify-center items-center"
        >
          <Badge>Disponible para trabajar</Badge>
        </a>
      </h1>
      <h2 class="text-2xl opacity-80 text-wrap pb-4">
        <span class="text-yellow-200">Desarrollador Web Frontend.</span>
        <span class="text-red-200">De Mendoza, Argentina🧉.</span> 
        <span class="opacity-80">En continua formación y búsqueda de conocimientos.👨‍💻</span>
      </h2>
      <ul class="flex flex-wrap gap-4 text-wrap">
        <li>
          <NetworkPill  href="https://www.linkedin.com/in/maiten-oviedo/">
            <LinkedInIcon class="size-4" />
            LinkedIn
          </NetworkPill>
				</li>
				<li class="flex gap-4 text-wrap">
          <NetworkPill href="https://github.com/Maiten-Oviedo">
            <GithubIcon class="size-4"/>
            GitHub
          </NetworkPill>
				</li>
				<li class="flex gap-4 text-wrap">
          <NetworkPill href="https://www.linkedin.com/in/maiten-oviedo/">
            <InstagramIcon class="size-4"/>
            Instagram
          </NetworkPill>
				</li>
				<li class="flex gap-4 text-wrap">
          <NetworkPill href="https://www.linkedin.com/in/maiten-oviedo/">
            <MailIcon class="size-4"/>
            maitenoviedo513@gmail.com
          </NetworkPill>
				</li>
      </ul>
    </SectionContainer>
    <SectionContainer id="projects-section" class="py-2 w-full px-[25%] pb-20">
      <Proyects/>
    </SectionContainer>
    <SectionContainer id="about-section" class="w-full px-[25%] pt-4">
      <Studies/>
    </SectionContainer>
    <SectionContainer id="contact-section" class="w-full px-[25%]">
    </SectionContainer>
  </main>
</Layout>
