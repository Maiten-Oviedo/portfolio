---
import Layout from '@/layouts/Layout.astro'
import Header from '@/components/Header.astro'
import Hero from '@/components/sections/Hero.astro'
import Roots from '@/components/sections/Roots.astro'
import Experience from '@/components/sections/Experience.astro'
import Projects from '@/components/sections/Projects.astro'
import Contact from '@/components/sections/Contact.astro'
import Footer from '@/components/Footer.astro'
---

<Layout
  description="Soy Maitén Oviedo, Desarrollador Full Stack en Mendoza especializado en frontend y aplicaciones web modernas."
  title="Maitén Oviedo - Desarrollador Full Stack | Portfolio"
>
  <Header />
  
  <main class="relative min-h-screen pt-24 overflow-hidden bg-background">
    <div class="relative z-10 w-full flex flex-col gap-20">
      <Hero />
      <Experience />
      <Projects />
      <Roots />
      <Contact />
    </div>
  </main>
  
  <Footer />
</Layout>
