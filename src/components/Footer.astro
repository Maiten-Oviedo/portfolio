---
const { class: className = "" } = Astro.props;
const currentYear = new Date().getFullYear();

// Schema Markup for SEO
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Maitén Oviedo",
  "jobTitle": "Desarrollador Full Stack",
  "url": "https://maitendev.vercel.app/",
  "sameAs": [
    "https://github.com/Maiten-Oviedo",
    "https://www.linkedin.com/in/maiten-oviedo",
    "https://www.instagram.com/maiten_oviedo"
  ]
};
---

<footer class={`w-full py-20 px-6 md:px-12 flex flex-col md:flex-row justify-between items-center gap-12 bg-emerald-950/20 rounded-t-[4rem] mt-32 border-t border-emerald-500/10 film-grain ${className}`}>
  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <div class="flex flex-col items-center md:items-start gap-4">
    <div class="flex items-center gap-3">
       <img src="/favicon.svg" alt="Maitén Logo" class="w-8 h-8 opacity-50" />
       <div class="text-2xl font-headline text-emerald-50">Maitén <span class="italic text-emerald-300/80">Oviedo</span></div>
    </div>
    <p class="font-label text-[10px] text-emerald-100/30 uppercase tracking-[0.4em]">© {currentYear} — Construido con integridad y precisión técnica.</p>
  </div>
  
  <div class="flex flex-wrap justify-center gap-8 font-label text-[10px] uppercase tracking-widest text-emerald-100/40">
    <span class="hover:text-emerald-300 transition-colors cursor-default">Arquitectura Limpia</span>
    <span class="hover:text-emerald-300 transition-colors cursor-default">UX Bio-Orgánico</span>
    <span class="hover:text-emerald-300 transition-colors cursor-default">Mendoza, AR</span>
  </div>
  
  <div class="flex gap-6 items-center">
    <a href="https://github.com/Maiten-Oviedo" target="_blank" rel="noopener noreferrer" class="text-emerald-500/40 hover:text-emerald-400 transition-all flex items-center justify-center p-2">
       <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
    </a>
    <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="w-14 h-14 rounded-full border border-emerald-500/20 flex items-center justify-center text-emerald-400 hover:bg-emerald-500 hover:text-background transition-all cursor-pointer group shadow-organic" aria-label="Volver arriba">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-y-1 transition-all"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>
    </button>
  </div>
</footer>
