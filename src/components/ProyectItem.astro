---

interface Props{
	name: string;
	alt: string;
	description: string;
	technologies: [];
	url: string;
	img: string;
}

const {name, alt, description, technologies, url, img} = Astro.props;
---


<div class="m-auto md:m-0 flex flex-col justify-between max-w-[350px] bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
	<a class="relative" href={url} target="_blank" rel="noopener noreferrer">
		<div class="absolute top-0 w-full h-full bg-[linear-gradient(rgba(8,27,41,0.8),rgba(8,27,41,0.8))] flex justify-center items-center transition opacity-0 hover:opacity-100">
			<h3 class="text-xl font-bold">Visitar</h3>
		</div>
		<img class="rounded-t-lg" src={img} alt={alt}/>
	</a>
	<div class="px-5 pt-4">
			<a href="#">
					<h5 class="mb-2 text-xl font-bold tracking-tight text-gray-900 dark:text-white">{name}</h5>
			</a>
			<p class="text-sm mb-3 font-normal text-gray-700 dark:text-gray-400">{description}</p>
	</div>
	<ul class="flex justify-center gap-4 pb-2">
		{technologies.map((tech) => {
			return  <li><img src={`/assets/icons/${tech}.svg`} alt={tech} class="w-6 h-6" /></li>
		})}
	</ul>
</div>