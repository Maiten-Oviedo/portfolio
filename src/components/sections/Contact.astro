---
// Contact.astro - Sección de contacto profesional
const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  mainEntity: {
    "@type": "Person",
    name: "Maitén Oviedo",
    jobTitle: "Desarrollador Full Stack",
    email: "maitenoviedo513@gmail.com",
    sameAs: [
      "https://github.com/Maiten-Oviedo",
      "https://www.linkedin.com/in/maiten-oviedo",
      "https://www.instagram.com/maiten_oviedo",
    ],
    contactPoint: {
      "@type": "ContactPoint",
      telephone: "+5492613897545",
      contactType: "personal",
    },
  },
};
---

<section
  id="contacto"
  class="pt-32 pb-20 px-6 container mx-auto min-h-[80vh] flex flex-col justify-center"
  aria-labelledby="contact-heading"
>
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <!-- Header Section -->
  <header
    class="mb-24 flex flex-col md:flex-row md:items-end justify-between gap-10 animate-fade-in-up"
  >
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-3 mb-6">
        <span class="w-8 h-[1px] bg-emerald-500/30"></span>
        <span
          class="font-label text-[10px] uppercase tracking-[0.4em] text-emerald-400/80"
          >Canales de Comunicación</span
        >
      </div>
      <h2
        id="contact-heading"
        class="text-6xl md:text-8xl font-headline text-emerald-50 leading-[0.9]"
      >
        Hablemos de tu <br />
        <span class="italic text-emerald-300">Próximo Paso.</span>
      </h2>
    </div>
    <div
      class="relative w-full md:w-1/3 aspect-[4/3] organic-mask overflow-hidden bg-emerald-950/20 group border border-emerald-500/10 shadow-2xl"
    >
      <img 
        src="/assets/images/contact.webp" 
        alt="Contacto - Maitén Oviedo" 
        class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-emerald-950/60 via-transparent to-transparent opacity-80"
      >
      </div>
    </div>
  </header>

  <!-- Main Grid -->
  <div
    class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start animate-slide-up"
    style="animation-delay: 0.2s;"
  >
    <!-- Contact Form Area (Bento Left) -->
    <div
      class="lg:col-span-7 bg-emerald-950/20 blob-card p-10 md:p-14 relative overflow-hidden group hover:border-emerald-500/20 transition-all border border-emerald-500/10 shadow-lg"
    >
      <div class="relative z-10">
        <h3 class="font-headline text-3xl mb-10 text-emerald-50">
          Consulta Directa
        </h3>
        <form
          id="contact-form"
          class="space-y-8"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-3">
              <label
                class="font-label text-[10px] uppercase tracking-[0.2em] text-emerald-400/50 ml-1"
                >Tu Nombre</label
              >
              <input
                class="w-full bg-emerald-500/5 border border-emerald-500/10 rounded-2xl py-5 px-8 text-emerald-50 placeholder:text-emerald-300/20 focus:ring-1 focus:ring-emerald-500/40 transition-all outline-none font-body"
                placeholder="Ej: Juan Pérez"
                type="text"
                name="name"
                required
              />
            </div>
            <div class="space-y-3">
              <label
                class="font-label text-[10px] uppercase tracking-[0.2em] text-emerald-400/50 ml-1"
                >Tu Correo</label
              >
              <input
                class="w-full bg-emerald-500/5 border border-emerald-500/10 rounded-2xl py-5 px-8 text-emerald-50 placeholder:text-emerald-300/20 focus:ring-1 focus:ring-emerald-500/40 transition-all outline-none font-body"
                placeholder="email@ejemplo.com"
                type="email"
                name="email"
                required
              />
            </div>
          </div>
          <div class="space-y-3">
            <label
              class="font-label text-[10px] uppercase tracking-[0.2em] text-emerald-400/50 ml-1"
              >Tu Mensaje</label
            >
            <textarea
              class="w-full bg-emerald-500/5 border border-emerald-500/10 rounded-2xl py-5 px-8 text-emerald-50 placeholder:text-emerald-300/20 focus:ring-1 focus:ring-emerald-500/40 transition-all resize-none outline-none font-body"
              placeholder="Contame sobre tu proyecto o necesidad técnica..."
              rows="5"
              name="message"
              required></textarea>
          </div>
          <button
            id="submit-button"
            class="blob-button group/btn relative inline-flex items-center justify-center gap-4 px-12 py-6 bg-emerald-500/20 text-emerald-50 font-label text-xs font-bold uppercase tracking-[0.2em] transition-all hover:bg-emerald-500/40 active:scale-95 border border-emerald-500/20 shadow-organic cursor-pointer w-full md:w-auto"
            type="submit"
          >
            <span id="button-text">Enviar Mensaje</span>
            <span
              id="button-icon"
              class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </span>
          </button>
          <div id="form-status" class="mt-6 text-[10px] font-label uppercase tracking-[0.2em] hidden"></div>
        </form>
      </div>

      <!-- Subtle organic background decoration -->
      <div
        class="absolute -bottom-10 -right-10 w-40 h-40 bg-emerald-500/5 blur-[80px] group-hover:bg-emerald-500/10 transition-all"
      >
      </div>
    </div>

    <!-- Sidebar Info (Bento Right) -->
    <div class="lg:col-span-5 space-y-10">
      <!-- Direct Connection -->
      <div
        class="bg-emerald-950/20 blob-card p-10 border border-emerald-500/10 group hover:border-emerald-500/20 transition-all shadow-md"
      >
        <h3 class="font-headline text-2xl mb-4 text-emerald-50">
          Contacto Directo
        </h3>
        <p class="text-emerald-100/50 text-base mb-8 leading-relaxed font-body">
          Si preferís una respuesta inmediata para consultas técnicas urgentes,
          podés escribirme directamente por WhatsApp.
        </p>
        <a
          href="https://wa.me/+5492613897545"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-5 p-5 bg-emerald-500/5 rounded-2xl group/wa hover:bg-emerald-500/10 transition-all border border-emerald-500/10 hover:border-emerald-500/30"
        >
          <div
            class="w-14 h-14 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-300 shadow-inner group-hover/wa:scale-110 transition-transform"
          >
            <div class="w-6 h-6 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            </div>
          </div>
          <div class="flex-1">
            <span
              class="block font-label text-[9px] uppercase tracking-[0.2em] text-emerald-400 group-hover/wa:text-emerald-300 transition-colors"
              >WhatsApp</span
            >
            <span class="block text-emerald-50 font-medium text-lg"
              >+54 261 389 7545</span
            >
          </div>
          <span
            class="text-emerald-500/30 group-hover/wa:text-emerald-400 group-hover/wa:translate-x-1 transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </span>
        </a>
      </div>

      <!-- Social Networks -->
      <div class="bg-emerald-950/10 blob-card p-10 border border-emerald-500/5">
        <span
          class="font-label text-[10px] uppercase tracking-[0.4em] text-emerald-400/30 mb-10 block"
          >Redes & Perfiles</span
        >
        <div class="grid grid-cols-2 gap-6">
          {
            [
              {
                name: "LinkedIn",
                url: "https://www.linkedin.com/in/maiten-oviedo",
                icon: "account_tree",
              },
              {
                name: "GitHub",
                url: "https://github.com/Maiten-Oviedo",
                icon: "terminal",
              },
              {
                name: "Email",
                url: "mailto:maitenoviedo513@gmail.com",
                icon: "mail",
              },
              {
                name: "Instagram",
                url: "https://www.instagram.com/maiten_oviedo",
                icon: "camera_enhance",
              },
            ].map((soc) => (
              <a
                class="flex flex-col gap-4 p-6 rounded-2xl bg-emerald-950/20 hover:bg-emerald-500/10 transition-all group/soc border border-emerald-500/5 hover:border-emerald-500/20"
                href={soc.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-emerald-500/5 text-emerald-400 group-hover/soc:bg-emerald-500 group-hover/soc:text-background transition-all">
                  {soc.icon === 'account_tree' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v12"></path><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>
                  )}
                  {soc.icon === 'terminal' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
                  )}
                  {soc.icon === 'mail' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  )}
                  {soc.icon === 'camera_enhance' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                  )}
                </div>
                <span class="font-label text-[10px] uppercase tracking-widest text-emerald-100/60 group-hover/soc:text-emerald-50 transition-colors">
                  {soc.name}
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    const submitBtn = document.getElementById('submit-button');
    const btnText = document.getElementById('button-text');

    if (form && status && submitBtn && btnText) {
      let emailjsModule = null;

      const loadEmailJS = async () => {
        if (emailjsModule) return emailjsModule;
        try {
          const { default: emailjs } = await import('https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/index.js');
          emailjsModule = emailjs;
          console.log('EmailJS loaded from CDN');
          return emailjs;
        } catch (err) {
          console.error('Error loading EmailJS:', err);
          return null;
        }
      };

      // Preload on focus
      const inputs = form.querySelectorAll('input, textarea');
      const handleFocus = () => {
        loadEmailJS();
        inputs.forEach(input => input.removeEventListener('focus', handleFocus));
      };
      inputs.forEach(input => input.addEventListener('focus', handleFocus));

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const originalText = btnText.innerText;
        btnText.innerText = 'Enviando...';
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.5';
        submitBtn.style.cursor = 'not-allowed';
        status.classList.add('hidden');
        
        try {
          const emailjs = await loadEmailJS();
          if (!emailjs) throw new Error('No se pudo cargar el servicio de correo.');
          
          await emailjs.sendForm(
            'service_h3li6th',
            'template_x41tw8l',
            form,
            'rJF-FnyRQ_fCYBrEB'
          );
          
          status.innerText = '¡Mensaje enviado con éxito! Te responderé pronto.';
          status.className = 'mt-6 text-[10px] font-label uppercase tracking-[0.2em] text-emerald-400 block animate-fade-in';
          form.reset();
          
          setTimeout(() => {
            status.classList.add('hidden');
            status.classList.remove('block');
          }, 5000);

        } catch (error) {
          console.error('Error:', error);
          status.innerText = 'Hubo un problema. Por favor, reintentá o escribime por WhatsApp.';
          status.className = 'mt-6 text-[10px] font-label uppercase tracking-[0.2em] text-red-400 block animate-fade-in';
        } finally {
          btnText.innerText = originalText;
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          submitBtn.style.cursor = 'pointer';
        }
      });
    }
  })();
</script>
