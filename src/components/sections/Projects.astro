---
import { projects } from "@/constants/projects";

const projectsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Proyectos de Maitén Oviedo",
  description:
    "Portfolio de proyectos Full Stack enfocados en arquitectura sólida y rendimiento.",
  numberOfItems: projects.length,
  itemListElement: projects.map((p, i) => ({
    "@type": "CreativeWork",
    position: i + 1,
    name: p.title,
    description: p.description,
    url: p.url,
  })),
};

const mainProjects = projects.filter((p) => p.number !== "04.");
const apiProject = projects.find((p) => p.number === "04.");
---

<script type="application/ld+json" set:html={JSON.stringify(projectsSchema)} />

<section
  id="proyectos"
  class="pb-20 px-6 w-full container mx-auto"
  aria-labelledby="projects-heading"
>
  <!-- Section Header -->
  <header class="mb-24 flex flex-col items-start gap-4">
    <div class="flex items-center gap-3 mb-2 animate-fade-in-up">
      <span class="w-12 h-[1px] bg-emerald-500/30"></span>
      <span
        class="font-label text-[10px] uppercase tracking-[0.4em] text-emerald-400/80"
        >Proyectos Seleccionados</span
      >
    </div>
    <h2
      id="projects-heading"
      class="text-6xl md:text-8xl font-headline leading-[0.9] text-emerald-50 animate-slide-in-left"
    >
      Soluciones <br />
      <span class="italic text-emerald-300">Técnicas Reales.</span>
    </h2>
    <p
      class="mt-8 text-emerald-100/60 font-body max-w-xl text-lg leading-relaxed animate-fade-in-up"
      style="animation-delay: 0.2s;"
    >
      Una selección de desarrollos donde la prioridad es la integridad del
      código y la escalabilidad del sistema. Sin rodeos, solo ingeniería
      aplicada.
    </p>
  </header>

  <!-- Projects Bento Grid -->
  <div
    class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 animate-slide-up"
    style="animation-delay: 0.3s;"
  >
    <!-- Project 1: Large Feature -->
    <a 
      href={projects[0].url} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="md:col-span-7 group relative"
    >
      <div
        class="relative bg-emerald-950/20 blob-card p-1 border border-emerald-500/10 shadow-sm group-hover:shadow-xl group-hover:border-emerald-500/30 transition-all duration-500 h-full"
      >
        <!-- Floating Link Icon -->
        <div class="absolute top-6 right-6 z-30 w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 opacity-0 group-hover:opacity-100 transition-all duration-500 group-hover:translate-y-0 translate-y-4">
          <span class="material-symbols-outlined text-xl">open_in_new</span>
        </div>

        <div
          class="block relative overflow-hidden h-[450px] organic-mask bg-emerald-950/40"
        >
          <img
            src="/assets/images/project-oselectricsas.webp"
            alt="Landing Page de Oselectric Sas - Construcciones eléctricas y Energía Solar"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent opacity-80"
          >
          </div>
        </div>
        <div class="p-8 md:p-10">
          <div class="flex flex-wrap gap-3 mb-6">
            {
              projects[0].techs.map((tech) => (
                <span class="px-3 py-1 bg-emerald-500/5 rounded-full text-[9px] font-label tracking-widest text-emerald-300 uppercase border border-emerald-500/10">
                  {tech}
                </span>
              ))
            }
          </div>
          <h3 class="text-4xl font-headline mb-4 text-emerald-50 group-hover:text-emerald-300 transition-colors">
            {projects[0].title}
          </h3>
          <p
            class="text-emerald-100/60 text-base font-body max-w-md leading-relaxed"
          >
            {projects[0].description}
          </p>
        </div>
      </div>
    </a>

    <!-- Project 2 & API -->
    <div class="md:col-span-5 flex flex-col gap-12 justify-center">
      <a 
        href={projects[1].url}
        target="_blank" 
        rel="noopener noreferrer"
        class="group h-full flex flex-col"
      >
        <div
          class="bg-emerald-950/20 blob-card p-10 border border-emerald-500/10 group-hover:border-emerald-500/30 transition-all grow flex flex-col justify-between relative overflow-hidden"
        >
          <!-- Subtle link highlight on hover -->
          <div class="absolute top-0 right-0 p-6 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-x-4 group-hover:translate-x-0">
             <span class="material-symbols-outlined text-emerald-400">arrow_outward</span>
          </div>

          <div>
            <div class="flex justify-between items-start mb-12">
              <div
                class="w-14 h-14 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-400 shadow-inner"
              >
                <span
                  class="material-symbols-outlined text-3xl"
                  data-icon="terminal">terminal</span>
              </div>
              <span
                class="font-label text-[10px] text-emerald-400 uppercase tracking-[0.3em] bg-emerald-500/10 px-3 py-1 rounded-full"
                >Sistema Central</span
              >
            </div>
            <h3 class="text-3xl font-headline mb-4 text-emerald-50 group-hover:text-emerald-300 transition-colors">
              {projects[1].title}
            </h3>
            <p
              class="text-emerald-100/60 text-sm font-body mb-8 leading-relaxed"
            >
              {projects[1].description}
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            {
              projects[1].techs
                .slice(0, 3)
                .map((tech) => (
                  <span class="px-2 py-1 bg-emerald-500/5 rounded-md text-[8px] font-label tracking-widest text-emerald-300 uppercase border border-emerald-500/5">
                    {tech}
                  </span>
                ))
            }
          </div>
        </div>
      </a>

      <!-- API / Backend Link -->
      <a
        href={apiProject?.url}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-emerald-950/40 blob-card p-8 border border-emerald-500/10 flex items-center justify-between group hover:border-emerald-500/30 transition-all hover:bg-emerald-900/40"
      >
        <div>
          <span
            class="font-label text-[10px] text-emerald-400/60 uppercase mb-2 block tracking-widest"
            >Base de Datos & API</span
          >
          <h3
            class="font-headline text-xl text-emerald-50 group-hover:text-emerald-300 transition-colors"
          >
            {apiProject?.title}
          </h3>
        </div>
        <div
          class="w-12 h-12 rounded-full border border-emerald-500/20 flex items-center justify-center group-hover:bg-emerald-500 group-hover:text-background transition-all"
        >
          <span
            class="material-symbols-outlined text-lg"
            data-icon="arrow_forward">arrow_forward</span
          >
        </div>
      </a>
    </div>

    <!-- Project 3: Wide Layout -->
    <div class="md:col-span-12 mt-12">
      <a 
        href={projects[2].url}
        target="_blank" 
        rel="noopener noreferrer"
        class="relative block bg-emerald-950/20 blob-card overflow-hidden group border border-emerald-500/10 group-hover:border-emerald-500/30 transition-all p-4 md:p-8"
      >
        <div class="flex flex-col md:flex-row items-center">
          <div
            class="w-full md:w-1/2 h-80 md:h-[500px] overflow-hidden organic-mask bg-emerald-950/40 relative"
          >
            <img
              src="/assets/images/project-portfolio.webp"
              alt="Imágen de Portfolio - Portafolio para Administradora"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-105"
            />
            <div
              class="absolute inset-0 bg-gradient-to-tr from-background via-transparent to-transparent opacity-60"
            >
            </div>
          </div>
          <div
            class="w-full md:w-1/2 p-8 md:p-16 relative z-10 flex flex-col justify-center"
          >
            <div class="h-1 w-12 bg-emerald-500/30 mb-8 rounded-full"></div>
            <h3
              class="text-4xl md:text-5xl font-headline mb-6 leading-tight text-emerald-50 group-hover:text-emerald-300 transition-colors"
            >
              {projects[2].title}
            </h3>
            <p
              class="text-emerald-100/60 text-lg font-body mb-10 leading-relaxed max-w-md"
            >
              {projects[2].description}
            </p>
            <div class="flex flex-wrap gap-4 mb-12">
              {
                projects[2].techs.map((tech) => (
                  <span class="font-label tracking-widest text-[9px] uppercase text-emerald-300/80 px-3 py-1 bg-emerald-500/5 rounded-full border border-emerald-500/10">
                    {tech}
                  </span>
                ))
              }
            </div>
            <div
              class="blob-button inline-flex w-fit bg-emerald-500/20 text-emerald-50 px-10 py-5 font-label text-xs font-bold uppercase tracking-[0.2em] group-hover:bg-emerald-500/40 transition-all border border-emerald-500/20 shadow-organic"
            >
              Ver Proyecto
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
