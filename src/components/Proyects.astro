---
import ProyectItem from '../components/ProyectItem.astro'
import ProyectsIcon from '../icons/ProyectsIcon.astro'

const PROYECTS = [
	{
		name: 'Tienda de Hamburguesas',
		description: 'En esta página se puso en practica los conceptos de estados mas complejos como useContext y el paso de elementos como variables o métodos utilizando useReducer.',
		technologies: ['HtmlIcon', 'TailwindIcon', 'JavascriptIcon','ReactIcon', 'ViteIcon'],
		url: 'https://d-burgers.vercel.app/',
		img: '/assets/d-burgers.jpg'
	},
	{
		name: 'Tienda de Cervezas',
		description: 'Landing Page simple de una tienda de cervezas artesanalaes, en la que se aprendio el uso de componentes, estados y estructura de proyecto.',
		technologies: ['HtmlIcon', 'CssIcon', 'JavascriptIcon','ReactIcon'],
		url: 'https://panaholma-web.vercel.app/',
		img: '/assets/panaholma-page.jpg'
	},
	{
		name: 'Ecommerce',
		description: 'Tienda de ropa moderna, con un diseño minimalista y elegante. Cuenta con carrito utilizando localStorage. Hecha en el curso Argentina Programa - Primer Tramo',
		technologies: ['HtmlIcon', 'CssIcon', 'JavascriptIcon'],
		url: 'https://maiten-oviedo.github.io/Ecommerce/',
		img: '/assets/Ecommerce.jpg'
	},
	{
		name: 'Página de Libros',
		description: 'Página de libros, en la que puedes ver una serie de libros y añadirlos a tus favoritos, ademas tienes una seccion para marcar tus listas de libros por leer y otra para marcar los que ya terminaste.',
		technologies: ['HtmlIcon', 'CssIcon', 'JavascriptIcon'],
		url: 'https://github.com/Maiten-Oviedo/TrabajoFinal-ReactJs',
		img: '/assets/libros.jpg'
	},
	{
		name: 'Ta-Te-Ti',
		description: 'Juego interactivo clásico Ta Te Ti, revisa mi repositorio!',
		technologies: ['HtmlIcon', 'CssIcon', 'JavascriptIcon'],
		url: 'https://github.com/Maiten-Oviedo/Ta-Te-Ti',
		img: '/assets/tateti.jpg'
	}
]
---
<h3 class="text-3xl pb-10 font-bold flex items-center gap-3"><ProyectsIcon class="size-8"/> Proyectos</h3>
<ol class="flex flex-wrap justify-between gap-5">
	{PROYECTS.map(proyect=>{
		return <ProyectItem {...proyect}/>
	})}
</ol>

