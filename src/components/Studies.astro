---
import StudiesItem from './StudiesItem.astro'

const STUDIES = [
  {
    name: 'Bachillerato en Informática',
    institution: 'Escuela Secundaria Arq. Carlos Thays.',
    period: '2016 - 2020',
    description:
      'Estudios de bachillerato en informática, con énfasis en programación y redes de computadoras. Se cursaron 5 años de estudios en los que aprendi las bases de HTML, CSS, y JavaScript. Además exploré Ardiuno!',
  },
  {
    name: 'Curso | Argentina Programa - Primer Tramo',
    institution: 'Universidad Tecnológica Nacional',
    period: '3/2023 - 5/2022',
    description:
      'Los estudios se basaron en HTML, CSS y JavaScript. En este curso como proyecto final realice un Eccomerce trabajando en grupo.',
  },
  {
    name: 'Curso | Argentina Programa - Segundo Tramo',
    institution: 'Universidad Tecnológica Nacional',
    period: '10/2023 - 12/2022',
    description:
      'En este curso aprendi las bases de React Js, componentes, hooks, estructura de proyectos, etc. Aquí, el proyecto final se basó en realizar una landing page que trataba sobre libros.',
  },
  {
    name: 'Tecnicatura Superior en Informática',
    institution: 'Universidad Tecnológica Nacional',
    period: '6/2023 - Presente',
    description:
      'La Licenciatura en Administración te capacita en la gestión eficiente de recursos en organizaciones. Aprenderás a planificar, organizar y dirigir entidades, abordando aspectos comerciales, operativos y financieros. La carrera te prepara para asumir roles de liderazgo con una visión global para resolver problemas y tomar decisiones estratégicas.',
  },
]
---

<ol class="relative border-s border-gray-200 dark:border-gray-700 w-full pl-6">
  {
    STUDIES.map(proyect => {
      return <StudiesItem {...proyect} />
    })
  }
</ol>
