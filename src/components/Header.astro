---
// Header.astro
---

<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-8 py-4 max-w-full bg-emerald-950/80 backdrop-blur-xl border-b border-emerald-500/10">
  <div class="flex items-center gap-3 text-2xl font-headline italic text-emerald-100 film-grain group cursor-pointer logo-3d-wrap">
    <div class="logo-3d-inner animate-float-organic">
      <img src="/favicon.svg" alt="Logo Árbol de Maitén" class="w-10 h-10" />
    </div>
    <span class="hidden sm:inline-block hover:text-emerald-300 transition-colors duration-300">Maitén Oviedo</span>
  </div>
  <nav class="hidden md:flex items-center gap-2">
    <a
      class="text-emerald-100 hover:text-emerald-50 transition-all duration-300 font-label tracking-wider text-xs uppercase hover:bg-emerald-900/60 rounded-lg px-4 py-2"
      href="#contacto"
    >Contacto</a>
  </nav>
  <div class="flex items-center gap-4">
    <a 
      href="/CV-MaitenOviedo.pdf" 
      target="_blank"
      aria-label="Descargar currículum vitae en PDF"
      class="hidden sm:flex items-center gap-2 px-4 py-2 bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 border border-emerald-500/20 rounded-xl transition-all duration-300 text-xs font-label uppercase tracking-widest"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      CV
    </a>
    <button aria-label="Cambiar tema (Luz/Oscuridad)" class="p-2 text-emerald-400 hover:bg-emerald-900/60 rounded-lg transition-all duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8a7 7 0 0 1-7 7c-.32 0-.64-.03-.95-.08C13 18 12.33 19 11 20z"></path></svg>
    </button>
  </div>
</header>

<script>
  const wrap = document.querySelector('.logo-3d-wrap') as HTMLElement;
  const inner = document.querySelector('.logo-3d-inner') as HTMLElement;

  if (wrap && inner) {
    wrap.addEventListener('mousemove', (e) => {
      const rect = wrap.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      
      const rotateX = (y - centerY) / 15;
      const rotateY = (centerX - x) / 15;
      
      inner.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.1)`;
    });

    wrap.addEventListener('mouseleave', () => {
      inner.style.transform = `rotateX(0deg) rotateY(0deg) scale(1)`;
    });
  }
</script>

<style>
  /* Optional script logic to handle active styling based on scroll could be added here, but static handles it gracefully. */
</style>
